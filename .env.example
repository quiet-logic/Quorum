# Copy to .env and fill in for local dev (never commit .env)

SECRET_KEY=change-me-to-a-long-random-string
DB_PATH=quorum.db

# Email (leave blank to print emails to console in dev)
RESEND_API_KEY=
EMAIL_FROM=Quorum <noreply@yourdomain.com>
APP_URL=http://localhost:5173

# Set to 1 to skip email verification in dev
SKIP_EMAIL_VERIFY=1

# Stripe — get these from dashboard.stripe.com
# Use sk_test_... / whsec_... during development
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
